# MadeUpTasks API (started via module2/docker-compose.yml)
MADEUPTASKS_API_URL=http://localhost:8090/api/v1
MADEUPTASKS_API_TOKEN=tf_token_alice

# LLM Provider — set ONE of these depending on your provider
ANTHROPIC_API_KEY=sk-ant-...

# For OpenAI instead of Anthropic (see BaselineAgent.OpenAI example):
# OPENAI_API_KEY=sk-...

# For local models via Ollama:
# OLLAMA_BASE_URL=http://localhost:11434
