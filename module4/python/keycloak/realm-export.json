{
  "id": "workshop",
  "realm": "workshop",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "viewer",
        "description": "Can view tasks and assignments",
        "composite": false
      },
      {
        "name": "admin",
        "description": "Can view, create, assign, and close tasks",
        "composite": false
      },
      {
        "name": "default-roles-workshop",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": ["offline_access", "uma_authorization"]
        }
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}",
        "composite": false
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false
      }
    ],
    "client": {
      "mcp-client": [],
      "project-api": []
    }
  },
  "defaultRole": {
    "name": "default-roles-workshop",
    "description": "${role_default-roles}",
    "composite": true
  },
  "clientScopes": [
    {
      "name": "tasks:read",
      "description": "Read access to tasks",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "View project tasks"
      },
      "protocolMappers": [
        {
          "name": "tasks:read-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "project-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "tasks:read-scope-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "tasks_read",
            "claim.value": "true",
            "jsonType.label": "boolean",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "tasks:admin",
      "description": "Admin access to tasks (create, close)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Manage project tasks (create, close)"
      },
      "protocolMappers": [
        {
          "name": "tasks:admin-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "project-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "openid",
      "description": "OpenID Connect scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "consent.screen.text": "${emailScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "mcp-server",
      "name": "MCP Server",
      "description": "Confidential client for MCP Server OAuth proxy",
      "enabled": true,
      "publicClient": false,
      "secret": "mcp-server-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": ["http://localhost:8000/*", "http://localhost:8001/*"],
      "webOrigins": ["http://localhost:8000", "http://localhost:8001"],
      "protocol": "openid-connect",
      "fullScopeAllowed": false,
      "defaultClientScopes": ["openid", "email", "profile"],
      "optionalClientScopes": ["tasks:read", "tasks:admin"]
    },
    {
      "clientId": "mcp-client",
      "name": "MCP Client",
      "description": "Public client for MCP OAuth authorization code flow",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": ["http://localhost:*"],
      "webOrigins": ["http://localhost:*"],
      "protocol": "openid-connect",
      "fullScopeAllowed": false,
      "defaultClientScopes": ["openid", "email", "profile"],
      "optionalClientScopes": ["tasks:read", "tasks:admin"]
    },
    {
      "clientId": "project-api",
      "name": "Project Management API",
      "description": "Bearer-only resource server for the project management API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": false,
      "defaultClientScopes": [],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@workshop.local",
      "firstName": "Alice",
      "lastName": "Viewer",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer", "default-roles-workshop"],
      "clientRoles": {}
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@workshop.local",
      "firstName": "Bob",
      "lastName": "Admin",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "default-roles-workshop"],
      "clientRoles": {}
    }
  ],
  "scopeMappings": [
    {
      "clientScope": "tasks:read",
      "roles": ["viewer", "admin"]
    },
    {
      "clientScope": "tasks:admin",
      "roles": ["admin"]
    }
  ],
  "clientScopeMappings": {}
}
