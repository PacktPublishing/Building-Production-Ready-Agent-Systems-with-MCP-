# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak connection (used by project-api and MCP server)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=workshop

# Project API settings
EXPECTED_AUDIENCE=project-api
PROJECT_API_URL=http://localhost:3000

# Token exchange settings (McpServer.TokenExchange only)
MCP_SERVER_CLIENT_ID=mcp-server
MCP_SERVER_CLIENT_SECRET=mcp-server-secret
TARGET_AUDIENCE=project-api

# Agent identity for Level 3 delegation (optional)
AGENT_CLIENT_ID=agent-baseline
AGENT_CLIENT_SECRET=agent-baseline-secret
